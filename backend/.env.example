NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME=Flourish Hub Backend
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000
TRUST_PROXY=1
DATABASE_URL=postgresql://postgres:postgres@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:postgres@db.project-ref.supabase.co:5432/postgres?sslmode=require
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
CACHE_TTL_SECONDS=60

# Email Configuration (for OTP verification)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Quiz webhook secret — must match the secret in Google Apps Script
QUIZ_WEBHOOK_SECRET=replace_with_a_long_random_secret
